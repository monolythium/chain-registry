# --- Monolythium Vision base .gitignore (applies to every repo) ---

# Local-only development context (NEVER push these)
CLAUDE.md
.claude/local/
.claude/skills/
.gemini/
plans/
docs-internal/
*.internal.md
AUDIT-*.md
RESUME.md
STATUS.md
TODO.md

# Environment + secrets
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.keystore
*.p12
secrets/

# Cosign keyless signing certificates for the canonical milestone configs are
# PUBLIC Fulcio certs (the verifier needs them) — track them despite *.pem above.
!chains/milestones/*.pem
credentials/

# Node tooling (validator dependency — restored via `npm ci`)
node_modules/

# OS / editor cruft
.DS_Store
Thumbs.db
